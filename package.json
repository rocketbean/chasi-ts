{
  "name": "chasi-ts",
  "version": "4.1.3",
  "chasiVersion": "4.1.3",
  "description": "",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "chasis": "node_modules/@rocketbean/chasis/dist/chasis.js"
  },
  "scripts": {
    "test": "vitest --config ./vitest.config.ts",
    "start": "tsc && node ./dist/server.js -e ts --experimental-top-level-await ",
    "dev": "tsc-watch --resolveJsonModule --onSuccess  \"node ./dist/server.js -e ts  --experimental-top-level-await \"",
    "dev:html": "npm run postbuild && nodemon ./dist/server.js -e html,js,css,vue --experimental-top-level-await",
    "postbuild": "cpy \"./src/container/html/* \" \"./dist/container/html \" && cpy \"src/container/prisma/client/**\" \"dist/container/prisma/client\" --parents",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d && npm run db:migrate",
    "prisma:generate": "prisma generate --schema=src/container/prisma/schema.prisma",
    "prisma:migrate": "MYSQL_URL=${MYSQL_MIGRATE_URL:-mysql://root:root@localhost:3307/chasi} prisma migrate dev --schema=src/container/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/container/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/container/prisma/schema.prisma",
    "prisma:up": "docker compose up -d mysql && npm run prisma:migrate"
  },
  "nodemonConfig": {
    "ignore": [
      "./container/views",
      "dist/container/html",
      "dist/container/assets"
    ]
  },
  "author": "nikko mesina",
  "email": "buzzrocketbeab@gmail.com",
  "license": "ISC",
  "devDependencies": {
    "@rocketbean/create-chasi-ts": "^1.0.9",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@types/chalk": "^2.2.4",
    "@types/express": "^4.17.25",
    "@types/node": "^18.19.130",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/vue": "^2.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "cpy-cli": "^4.2.0",
    "lite-server": "^2.6.1",
    "log-update": "^5.0.1",
    "os-utils": "^0.0.14",
    "prisma": "^5.22.0",
    "shiki": "^1.29.2",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tsc-watch": "^6.3.1",
    "typescript": "^4.8.0-dev.20220630",
    "vite": "^5.4.21",
    "vitest": "^2.1.9",
    "vue-router": "^4.6.4"
  },
  "dependencies": {
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "animejs": "^3.2.2",
    "asynchronous-emitter": "^0.1.0",
    "axios": "^0.21.4",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^8.5.1",
    "letterizejs": "^2.0.1",
    "lodash": "^4.18.1",
    "mongodb": "^4.7.0",
    "mongoose": "^6.13.10",
    "npm-cache": "^0.7.0",
    "pg": "^8.22.0",
    "pinia": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "sass": "^1.101.0",
    "serve-static": "^1.16.3",
    "terser": "^5.48.0",
    "uuid": "^8.3.2",
    "vue": "^3.5.38",
    "ws": "^8.21.0"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=20.0.0"
  }
}
