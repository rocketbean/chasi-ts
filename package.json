{
  "name": "chasi-ts",
  "version": "4.2.0",
  "chasiVersion": "4.2.0",
  "description": "",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "chasis": "node_modules/@rocketbean/create-chasi-ts/dist/chasi.js"
  },
  "scripts": {
    "test": "vitest --config ./vitest.config.ts",
    "start": "tsc && node ./dist/server.js -e ts --experimental-top-level-await ",
    "dev": "tsc-watch --resolveJsonModule --onSuccess  \"node ./dist/server.js -e ts  --experimental-top-level-await \"",
    "dev:html": "npm run postbuild && nodemon ./dist/server.js -e html,js,css,vue --experimental-top-level-await",
    "postbuild": "cpy \"src/container/html/**\" \"dist/container/html\" && (cpy \"src/container/prisma/client/**\" \"dist/container/prisma/client\" || true)",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d && npm run db:migrate",
    "prisma:generate": "prisma generate --schema=src/container/prisma/schema.prisma",
    "prisma:migrate": "MYSQL_URL=${MYSQL_MIGRATE_URL:-mysql://root:root@localhost:3307/chasi} prisma migrate dev --schema=src/container/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/container/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/container/prisma/schema.prisma",
    "prisma:up": "docker compose up -d mysql && npm run prisma:migrate"
  },
  "nodemonConfig": {
    "ignore": [
      "./container/views",
      "dist/container/html",
      "dist/container/assets"
    ]
  },
  "author": "nikko mesina",
  "email": "buzzrocketbeab@gmail.com",
  "license": "ISC",
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rocketbean/create-chasi-ts": "^1.0.9",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-vue": "^6.0.7",
    "cpy-cli": "^7.0.0",
    "prisma": "^7.8.0",
    "shiki": "^4.2.0",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-router": "^4.6.4"
  },
  "dependencies": {
    "animejs": "^3.2.2",
    "asynchronous-emitter": "^0.1.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.2",
    "pg": "^8.22.0",
    "pinia": "^2.3.1",
    "sass": "^1.101.0",
    "serve-static": "^2.2.1",
    "terser": "^5.48.0",
    "uuid": "^14.0.1",
    "vue": "^3.5.38",
    "ws": "^8.21.0"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=20.19.0"
  }
}
