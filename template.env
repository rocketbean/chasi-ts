## app ##
APP_NAME=CHASI
APP_VERSION=2.0
mode=test
database=dev
databaseName=defaultDb
devDatabaseName=devdb
stageDatabaseName=stageDb
dbConStringLocal=mongodb://localhost:27017/
dbConStringStage=mongodb://localhost:27017/
dbConStringDev=mongodb://localhost:27017/
dbConStringTest=mongodb://localhost:27017/

## PostgreSQL (Drizzle) ##
PG_URL=postgresql://chasi:chasi@localhost:5433/chasi

## MySQL (Prisma) ##
MYSQL_URL=mysql://chasi:chasi@localhost:3307/chasi
MYSQL_MIGRATE_URL=mysql://root:root@localhost:3307/chasi

SSLcontainerKey=null
SSLcontainerCrt=null
ServerPort=3010
oauthkey=chasi

## environment ##
environment=local
devProtocol=https
devCert=../_security/cert.pem
devKey=../_security/key.pem


## log controls ##
Log_History=false
Log_Level=2

## APISPEC ##
APISPEC_ENABLED=true
APISPEC_OUTPUT=api.spec.json

## SdkBuilder ##
SDKBUILDER_ENABLED=true
SDKBUILDER_OUTPUT=api.sdk.js