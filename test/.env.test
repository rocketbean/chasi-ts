## environment ##
# NODE_ENV=test enables test-only behavior; CHASI_COMPILER=false skips the Vite
# build so the app boots from /src in-process (replaces the old testMode flag).
NODE_ENV=test
CHASI_COMPILER=false
environment=local

## app ##
database=dev
databaseName=defaultDb
devDatabaseName=o3dev
stageDatabaseName=stageDb
dbConStringLocal=mongodb://localhost:27017/
dbConStringStage=mongodb://localhost:27017/
dbConStringDev=mongodb://localhost:27017/
dbConStringTest=mongodb://localhost:27017/
SSLcontainerKey=null
SSLcontainerCrt=null
ServerPort=3013
oauthkey=chasi

## environment ##
environment=local
devProtocol=https
devCert=../_security/cert.pem
devKey=../_security/key.pem

## log controls ##
APP_STATE=1
DEV_DB="mysql://root:root@localhost:3306/dev"

## log controls ##
Log_History=false
Log_Level=0