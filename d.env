## app ##
APP_NAME=CHASI3
APP_VERSION=3.0
database=test
databaseName=defaultDb
devDatabaseName=devdb
testDatabaseName=testdb
dbConStringLocal=mongodb://localhost:27017/
dbConStringStage=mongodb://localhost:27017/
dbConStringDev=mongodb://localhost:27017/
dbConStringTest=mongodb://localhost:27017/

## PostgreSQL (Drizzle) ##
PG_URL=postgresql://chasi:chasi@localhost:5433/chasi

## MySQL (Prisma) ##
MYSQL_URL=mysql://chasi:chasi@localhost:3307/chasi
MYSQL_MIGRATE_URL=mysql://root:root@localhost:3307/chasi

SSLcontainerKey=null
SSLcontainerCrt=null
ServerPort=3010-3015
oauthkey=chasi

## environment ##
# please note that [testMode] will not 
# work on the dev/prod environment.
# testMode loads on /src.
environment=local
devProtocol=https
devCert=../_security/cert.pem
devKey=../_security/key.pem

## log controls ##
Log_History=false
Log_Level=2


# This was inserted by `prisma init`:
# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

PrismaDB="mysql://root:root@localhost:3306/dev"