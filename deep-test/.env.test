## ── deep-test environment ──────────────────────────────────────────────
## Mirrors test/.env.test. Unit tier needs almost none of this; the
## integration tier (DEEP_INTEGRATION=1) needs the DB/socket vars to point at
## real infra (see docker-compose.test.yml).

## environment ##
testMode="enabled"
environment=local

## app ##
database=test
databaseName=deepTestDb
devDatabaseName=deepDev
stageDatabaseName=deepStage
testDatabaseName=deepTest
dbConStringLocal=mongodb://localhost:27017/
dbConStringStage=mongodb://localhost:27017/
dbConStringDev=mongodb://localhost:27017/
dbConStringTest=mongodb://localhost:27017/
SSLcontainerKey=null
SSLcontainerCrt=null
ServerPort=3099
oauthkey=chasi-deep-test

## drizzle / prisma (integration tier only) ##
PG_URL=postgres://postgres:postgres@localhost:5433/deeptest
MYSQL_URL=mysql://root:root@localhost:3308/deeptest

## environment detail ##
devProtocol=https
devCert=../_security/cert.pem
devKey=../_security/key.pem

## log controls ##
APP_STATE=1
Log_History=false
Log_Level=0

## deep-test toggles ##
# DEEP_INTEGRATION=1   # set in shell to run the integration tier
# DEEP_VERBOSE=1       # set in shell to unmute framework boot logs
